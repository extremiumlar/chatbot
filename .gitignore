# Maxfiy kalitlar
.env

# Python
__pycache__/
*.pyc
.venv/
venv/

# Baza va saqlash (fayllar katta bo'ladi, git ga kirmasin)
storage/
data/raw/*
!data/raw/.gitkeep

# Katta / nozik fayllar (PII bo'lgan shartnomalar, master-reja PDF, loglar)
*.pdf
*.log
.claude/settings.local.json
anketalar/

# Django backend — baza va yuklangan rasmlar (kod emas, git ga kirmaydi)
backend/db.sqlite3
backend/media/

# Menejerlar anketasi (ichki sotuv javoblari) — public repoga kirmasin.
# Ma'lumot backend bazasiga import qilinadi (manage.py import_qa).
bilim_dataset.json

# OS
Thumbs.db
.DS_Store
