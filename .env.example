# Bu faylni nusxalab ".env" nomi bilan saqlang va kalitlarni to'ldiring.
# .env fayli hech qachon git ga qo'shilmasin (.gitignore da bor).

# --- LLM provayderi: "gemini" (asosiy) yoki "anthropic" ---
LLM_PROVIDER=gemini

# --- Google Gemini (LLM_PROVIDER=gemini bo'lsa kerak) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# (ixtiyoriy) asosiy model va kvota tugaganda sinaladigan zaxira modellar:
# MODEL_CHAT_GEMINI=gemini-2.5-flash-lite
# GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.5-flash

# --- Anthropic (Claude) — LLM_PROVIDER=anthropic bo'lsa yoki ingest.py uchun ---
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Telegram (userbot.py — shaxsiy akkaunt orqali javob beradi) ---
# https://my.telegram.org -> API development tools. Bitta api_id/api_hash
# BIR NECHTA Telegram akkaunt (lichka) uchun ham ishlatilaveradi:
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# (ixtiyoriy) asosiy akkauntning sessiya fayli nomi:
# TELEGRAM_SESSION=userbot
# Bir nechta akkaunt (lichka) ulash uchun: har birini ALOHIDA oynada
# "start.bat <nom>" bilan ishga tushiring (masalan: start.bat shahnoza,
# start.bat dilnoza) — bu .env o'zgartirish shart emas, --session
# argumenti TELEGRAM_SESSION'ni shu ishga tushirish uchun almashtiradi.
TELEGRAM_BOT_TOKEN=

# --- Instagram Messaging (rasmiy Meta Graph API — asosiy jonli kanal) ---
# Barchasi developers.facebook.com dagi Meta App'ingizdan olinadi:
# 1) Facebook Page yarating/ishlatiladigan Page'ni tanlang.
# 2) Instagram akkauntni Professional (Business) qilib, shu Page'ga ulang.
# 3) developers.facebook.com -> Create App -> "Other" -> "Business" -> Instagram mahsulotini qo'shing.
# 4) App Dashboard -> Settings -> Basic'da App ID/Secret ko'rinadi:
INSTAGRAM_APP_SECRET=
# 5) Instagram mahsuloti sozlamasida Page/IG akkauntga ruxsat berib, Page Access Token oling
#    (uzoq muddatlisiga almashtirish: graph.facebook.com/.../oauth/access_token?grant_type=fb_exchange_token...):
INSTAGRAM_PAGE_ACCESS_TOKEN=
# 6) O'zingiz o'ylab topgan tasodifiy satr — webhook sozlashda ham shu qiymatni kiritasiz:
INSTAGRAM_VERIFY_TOKEN=
# 7) graph.facebook.com/PAGE_ID?fields=instagram_business_account&access_token=... dan olinadi:
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# (ixtiyoriy) Graph API versiyasi:
# INSTAGRAM_GRAPH_API_VERSION=v21.0
# Webhook manzili (Meta App Dashboard -> Webhooks'ga kiritiladi):
#   https://<domeningiz>/api/instagram/webhook/

# --- Uysot showroom (jonli xonadon inventari) ---
# X-Auth tokeni (showroom API). Bo'sh bo'lsa bot umumiy bilim bazasiga tayanadi.
UYSOT_SHOWROOM_TOKEN=
# UYSOT_HOUSE_ID=880          # Nurli Diyor Residence
# UYSOT_CACHE_TTL=600         # inventar keshi (sekund)

# --- Xatti-harakat sozlamalari (hammasi ixtiyoriy, standart qiymatlari bor) ---
# HUMAN_TAKEOVER_MINUTES=30   # menejer qo'lda yozsa avtomatik javob shuncha to'xtaydi
# MODEL_TEMPERATURE=0.3       # javob aniqligi (past = aniqroq)
# RAG_ENABLED=1               # 0 -> RAG butunlay o'chadi (torch yuklanmaydi, engil VPS uchun)
# RAG_TOP_K=5                 # semantik qidiruvda olinadigan bo'laklar soni
# RAG_MIN_SCORE=0.45          # gibrid yakuniy balldan past bo'laklar tashlanadi
# RAG_VECTOR_WEIGHT=0.6       # gibrid ballda vektor ulushi (qolgani kalit-so'z)
# RAG_MIN_CONTRAST=0.05       # top-1 shu farqcha ajralib turmasa RAG promptga qo'shilmaydi
# EMBED_MODEL=intfloat/multilingual-e5-base  # almashtirsangiz: python ingest.py --rebuild
# FACTS_MIN_SCORE=0.25        # faktlar relevantlik chegarasi (promptga kirish uchun)
# FACTS_TOP_K=8               # promptga kiradigan maks. faktlar soni
# QA_MIN_SCORE=0.15           # rasmiy QA relevantlik chegarasi (past — QA ustuvor)
# QA_TOP_K=8                  # promptga kiradigan maks. QA soni

# --- Backend himoya va deploy ---
# BOT_API_TOKEN=uzun_tasodifiy_satr   # bot<->backend API himoyasi (ikkalasi shu .env'ni o'qiydi)
# DJANGO_SECRET_KEY=uzun_tasodifiy    # production'da MAJBURIY
# DJANGO_DEBUG=0                      # production'da 0
# DJANGO_ALLOWED_HOSTS=admin.example.uz,127.0.0.1
# PUBLIC_BASE_URL=https://admin.example.uz  # bot rasm URL'lari shu domendan (boshqa mashina bo'lsa)
# DJANGO_HTTPS=1                      # nginx TLS ortida bo'lsa cookie/HSTS yoqiladi
